{
  "name": "boltdocs",
  "version": "2.6.0",
  "description": "A lightweight documentation generator for React projects.",
  "main": "dist/node/index.mjs",
  "module": "dist/node/index.mjs",
  "types": "dist/node/index.d.ts",
  "bin": {
    "boltdocs": "bin/boltdocs.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.mjs",
      "require": "./dist/node/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./theme/neutral.css": "./dist/client/theme/neutral.css"
  },
  "files": [
    "dist",
    "bin",
    "src/client",
    "src/shared"
  ],
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "dev": "tsdown --watch --config-loader unrun",
    "format": "pnpm exec biome format --write",
    "lint": "pnpm exec biome lint --write",
    "check": "pnpm exec biome check --write"
  },
  "keywords": [
    "docs",
    "documentation",
    "static site generator",
    "ssg",
    "markdown",
    "mdx",
    "react",
    "vite",
    "typescript"
  ],
  "author": "Jesus Alcala",
  "license": "MIT",
  "dependencies": {
    "@mdx-js/rollup": "3.1.1",
    "@tailwindcss/vite": "4.2.2",
    "@vitejs/plugin-react": "6.0.1",
    "cac": "7.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "fast-glob": "3.3.3",
    "flexsearch": "0.8.212",
    "github-slugger": "2.0.0",
    "gray-matter": "4.0.3",
    "isomorphic-dompurify": "3.7.1",
    "lucide-react": "0.575.0",
    "react-aria-components": "1.16.0",
    "react-helmet-async": "^2.0.1",
    "react-router-dom": "^7.0.0",
    "rehype-slug": "6.0.0",
    "remark-frontmatter": "5.0.0",
    "remark-gfm": "4.0.1",
    "scroll-into-view-if-needed": "3.1.0",
    "sharp": "0.34.5",
    "shiki": "3.23.0",
    "svgo": "4.0.1",
    "tailwind-merge": "3.5.0",
    "unist-util-visit": "5.1.0",
    "vite": "7.0.0 || 8.0.0",
    "vite-plugin-image-optimizer": "2.0.3",
    "zod": "4.3.6",
    "@bdocs/ssg": "workspace:*"
  },
  "peerDependencies": {
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
    "@types/node": "22.0.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@types/react-router-dom": "5.3.3",
    "@types/semver": "7.7.1",
    "tsdown": "0.21.7",
    "typescript": "5.9.3"
  }
}