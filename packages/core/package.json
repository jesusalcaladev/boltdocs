{
  "name": "boltdocs",
  "version": "2.1.0",
  "description": "A lightweight documentation generator for React projects.",
  "main": "dist/node/index.js",
  "module": "dist/node/index.mjs",
  "types": "dist/node/index.d.ts",
  "bin": "dist/node/cli-entry.js",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.mjs",
      "require": "./dist/node/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.mjs",
      "require": "./dist/client/index.js"
    },
    "./client/hooks": {
      "types": "./dist/client/hooks/index.d.ts",
      "import": "./dist/client/hooks/index.mjs",
      "require": "./dist/client/hooks/index.js"
    },
    "./client/primitives": {
      "types": "./dist/client/components/primitives/index.d.ts",
      "import": "./dist/client/components/primitives/index.mjs",
      "require": "./dist/client/components/primitives/index.js"
    },
    "./client/types": {
      "types": "./dist/client/types.d.ts",
      "import": "./dist/client/types.mjs",
      "require": "./dist/client/types.js"
    },
    "./theme/neutral.css": "./src/client/theme/neutral.css"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "format": "pnpm exec biome format --write",
    "lint": "pnpm exec biome lint --write",
    "check": "pnpm exec biome check --write"
  },
  "keywords": [
    "docs",
    "documentation",
    "static site generator",
    "ssg",
    "markdown",
    "mdx",
    "react",
    "vite",
    "typescript"
  ],
  "author": "Jesus Alcala",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^4.2.1",
    "cac": "^7.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codesandbox": "^2.2.3",
    "fast-glob": "^3.3.3",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "isomorphic-dompurify": "^3.7.1",
    "lucide-react": "^0.575.0",
    "react-aria-components": "^1.16.0",
    "react-router-dom": "^6.30.3",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "scroll-into-view-if-needed": "^3.1.0",
    "sharp": "^0.34.5",
    "shiki": "^3.23.0",
    "svgo": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "unist-util-visit": "^5.1.0",
    "vite": "^7.3.1",
    "vite-plugin-image-optimizer": "^2.0.3"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^18.3.7",
    "@types/react-router-dom": "^5.3.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
