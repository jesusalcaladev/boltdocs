{
  "name": "@bdocs/plugin-mermaid",
  "version": "0.2.0",
  "description": "Mermaid diagram plugin for Boltdocs",
  "main": "dist/node/index.js",
  "module": "dist/node/index.mjs",
  "types": "dist/node/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/node/index.d.mts",
      "import": "./dist/node/index.mjs"
    },
    "./client": {
      "types": "./dist/client/index.d.mts",
      "import": "./dist/client/index.mjs"
    },
    "./style.css": "./dist/client/index.css"
  },
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "dev": "tsdown --watch --config-loader unrun"
  },
  "packageManager": "pnpm@10.30.2",
  "author": "Jesus Alcala",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "mermaid": "^11.12.3",
    "unist-util-visit": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0 || ^8.0.0"
  },
  "devDependencies": {
    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "boltdocs": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3"
  }
}
