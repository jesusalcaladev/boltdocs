{
  "name": "boltdocs-monorepo",
  "private": true,
  "scripts": {
    "preinstall": "pnpm -C packages/core build",
    "dev": "pnpm -C docs dev",
    "build:core": "pnpm --filter boltdocs build",
    "build:cli": "pnpm --filter @boltdocs/cli build",
    "build": "turbo run build",
    "release": "semantic-release",
    "preversion": "pnpm -r version ${npm_package_version} --no-git-tag-version",
    "audit": "pnpm audit"
  },
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "husky": "^9.0.1",
    "semantic-release": "^25.0.3",
    "turbo": "latest"
  }
}
