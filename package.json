{
  "name": "boltdocs-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm -C docs dev",
    "build:core": "pnpm --filter boltdocs build",
    "build": "turbo run build",
    "release": "pnpm build && pnpm changeset publish",
    "version-packages": "changeset version",
    "audit": "pnpm audit",
    "test": "vitest run --dir tests",
    "test:internal": "vitest run --dir internal-testing",
    "test:coverage": "vitest run --dir tests --coverage",
    "lint:md": "markdownlint-cli2 \"**/*.{md,mdx}\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.{md,mdx}\"",
    "format": "pnpm exec biome format --write .",
    "format:core": "pnpm exec biome format --write ./packages/core/src"
  },
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@biomejs/biome": "2.4.9",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "axe-core": "^4.11.4",
    "boltdocs": "workspace:*",
    "brace-expansion": "^2.1.0",
    "husky": "^9.0.1",
    "markdownlint-cli2": "^0.21.0",
    "turbo": "latest",
    "vite": "^7.0.0 || ^8.0.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.0.0",
      "react-dom": "19.0.0",
      "react-router-dom": "^7.0.0",
      "react-helmet-async": "^2.0.1",
      "cross-spawn": "^6.0.6",
      "next": "^15.5.14",
      "next-mdx-remote": "^6.0.0",
      "dompurify": "^3.3.2",
      "esbuild": "^0.25.0",
      "svgo": "^4.0.1",
      "flatted": "^3.4.2",
      "undici@^6": "6.24.0",
      "undici@^7": "7.24.0",
      "got": "^11.8.5",
      "axios": "^0.30.3",
      "ssri": "^8.0.1",
      "follow-redirects": "^1.15.5",
      "ip": "^2.0.1",
      "http-cache-semantics": "^4.1.1",
      "parse-git-config": "^3.0.0",
      "tmp": "^0.2.4",
      "handlebars": "^4.7.9",
      "brace-expansion": "^2.0.1",
      "picomatch": "^4.0.4",
      "yaml": "^2.8.3",
      "@babel/traverse": "^7.29.0",
      "brace-expansion": "^2.0.1",
      "minimatch": "^9.0.0",
      "test-exclude": "^7.0.1"
    },
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "sharp"
    ],
    "auditConfig": {
      "ignoreCves": [
        "CVE-2024-29415",
        "CVE-2023-42282",
        "CVE-2025-25975"
      ]
    }
  },
  "version": "1.11.0",
  "dependencies": {
    "@mdx-js/react": "^3.1.1"
  }
}
